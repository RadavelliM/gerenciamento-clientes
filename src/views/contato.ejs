<%- include('includes/head') %>

    <%- include('includes/navbar') %>

        <div class="container">
            <div class="row">
                <div class="col-lg-2"></div>

                <div class="col-lg-8 mt-2">
                    <h1 class="text-center">CRIE OU EDITE SEUS CONTATOS</h1>

                    <%- include('includes/messages') %>


                        <div class="row mt-5 formclass">
                            <div class="col-lg-8 text-center">
                                <h3>PREENCHA AS INFORMAÇÕES ABAIXO:</h3>

                                <% if(contato.id) { %>
                                    <form action="/contato/edit/<%= contato.id %>" method="POST">
                                        <% } else { %>
                                            <form class="contact" action="/contato/register" method="POST">

                                                <% } %>

                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                                    <div class="form-group">
                                                        <label for="exampleInputEmail1">Nome</label>
                                                        <input type="text" class="nome form-control" name="nome"
                                                            id="exampleInputEmail1" aria-describedby="emailHelp"
                                                            value="<%= contato.nome %>">
                                                    </div>

                                                    <div class="form-group">
                                                        <label for="exampleInputEmail1">Sobrenome</label>
                                                        <input type="text" class="sobrenome form-control" name="sobrenome"
                                                            id="exampleInputEmail1" aria-describedby="emailHelp"
                                                            value="<%= contato.sobrenome %>">
                                                    </div>

                                                    <div class="form-group">
                                                        <label for="exampleInputEmail1">Email</label>
                                                        <input type="email" class="email form-control" name="email"
                                                            id="exampleInputEmail1" aria-describedby="emailHelp"
                                                            value="<%= contato.email %>">
                                                    </div>

                                                    <div class="form-group">
                                                        <label for="exampleInputEmail1">Telefone</label>
                                                        <input type="tel" class="telefone form-control" name="telefone"
                                                            id="exampleInputEmail1" aria-describedby="emailHelp"
                                                            value="<%= contato.telefone %>">
                                                    </div>


                                                    <button type="submit"
                                                        class="btn btn-primary col-lg-8">Salvar</button>
                                            </form>
                            </div>
                        </div>
                </div>

                <div class="col-lg-2"></div>
            </div>
        </div>

        <%- include('includes/footer') %>